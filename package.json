{
  "name": "principal-simulator",

  "productName": "Principal Simulator",

  "version": "0.1.0",

  "description": "A simple high school management simulator.",

  "main": "electron/main.js",

  "author": "Your Name",

  "license": "GPL-3.0",

  "scripts": {
    "start": "electron .",

    "dev": "electron .",

    "pack": "electron-builder --dir",

    "dist": "electron-builder"
  },

  "devDependencies": {
    "electron": "^39.0.0",

    "electron-builder": "^26.0.12"
  },

  "build": {

    "appId": "com.principalsimulator.app",

    "directories": {
      "output": "dist"
    },

    "files": [

      "electron/**/*",

      "engine/**/*",

      "data/**/*",

      "index.html",

      "style.css",

      "README.md",

      "package.json"

    ],

    "win": {

      "target": [

        "portable",

        "zip",

        "msi"

      ]

    }

  }
}